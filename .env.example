# Git Repository Manager Environment Variables
# Copy this file to .env and update with your values

# Host path to your git repositories directory (mounted to /git in container)
# Examples: ~/git, /Users/username/projects, /home/user/repos
HOST_GIT_PATH=~/git

# Optional: additional mounts. The app scans one path at a time (set in Settings).
# Uncomment and set if you use multiple repo roots (e.g. worktrees, local-only).
# HOST_GIT_WD_PATH=~/git-wd
# HOST_GIT_LOCAL_PATH=~/git-local

# Optional API auth — if set, browser must send the same key (Settings → Browser API key)
# WEB_REPO_API_KEY=your-long-random-secret

# Default max git fetch operations per minute (token bucket; also in Settings)
# FETCH_MAX_PER_MINUTE=60
